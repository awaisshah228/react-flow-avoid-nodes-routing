{
  "name": "avoid-nodes-edge",
  "version": "0.2.3",
  "description": "Orthogonal edge routing for React Flow — edges avoid overlapping nodes via libavoid-js WASM running in a Web Worker.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./edge": {
      "types": "./dist/edge.d.ts",
      "import": "./dist/edge.js"
    },
    "./resolve-collisions": {
      "types": "./dist/resolve-collisions.d.ts",
      "import": "./dist/resolve-collisions.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@xyflow/react": ">=12.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zustand": ">=4.0.0",
    "libavoid-js": "0.4.5"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@xyflow/react": "^12.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.2",
    "zustand": "^5.0.10"
  },
  "keywords": [
    "react-flow",
    "reactflow",
    "xyflow",
    "edge-routing",
    "orthogonal",
    "libavoid",
    "wasm",
    "webassembly",
    "web-worker",
    "avoid-nodes",
    "turbo",
    "turborepo",
    "react",
    "diagram",
    "graph",
    "node-routing",
    "svg",
    "zustand"
  ],
  "homepage": "https://github.com/awaisshah228/react-flow-avoid-nodes-routing/tree/turbo-package/packages/avoid-nodes-edge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awaisshah228/react-flow-avoid-nodes-routing.git",
    "directory": "packages/avoid-nodes-edge"
  },
  "bugs": {
    "url": "https://github.com/awaisshah228/react-flow-avoid-nodes-routing/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Awais Shah (https://github.com/awaisshah228)"
}
