{
  "name": "avoid-nodes-router",
  "version": "0.3.0",
  "description": "Abstract edge routing engine for avoid-nodes. Transport-agnostic — works with any protocol (REST, WebSocket, SSE, etc).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "libavoid-js": "0.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.2"
  },
  "keywords": [
    "avoid-nodes",
    "edge-routing",
    "server",
    "transport-agnostic",
    "libavoid",
    "wasm",
    "react-flow"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "author": "Awais Shah (https://github.com/awaisshah228)"
}
